#!/bin/sh
# HISTFILE="$XDG_DATA_HOME"/zsh/history
HISTSIZE=1000000
SAVEHIST=1000000
export PATH="$HOME/.local/bin":$PATH
export MANPAGER='nvim +Man!'
export MANWIDTH=999
export PATH=$HOME/.cargo/bin:$PATH
export PATH=$HOME/.local/share/go/bin:$PATH
export GOPATH=$HOME/.local/share/go
export PATH="$PATH:./node_modules/.bin"
export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi
export PATH=$PATH:/opt/riscv/bin
export PATH=$PATH:/opt/llvm/bin
export PATH=$PATH:"/opt/riscv/riscv64-unknown-elf/bin"
export PATH=$PATH:"/opt/Xilinx/Vivado/2022.2/bin"
export PATH=$PATH:"/opt/bsc/latest/bin"
export PATH=$PATH:"$HOME/.local/share/Natural Docs"
export PATH=$PATH:"$HOME/.fzf/bin"
# opencode
export PATH=$HOME/.opencode/bin:$PATH
# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
# cas4k server specific
export PATH=$PATH:"/home/shared/texlive/bin/x86_64-linux"

PATH="/home/choucl/perl5/bin${PATH:+:${PATH}}"; export PATH;
PERL5LIB="/home/choucl/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"; export PERL5LIB;
PERL_LOCAL_LIB_ROOT="/home/choucl/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"; export PERL_LOCAL_LIB_ROOT;
PERL_MB_OPT="--install_base \"/home/choucl/perl5\""; export PERL_MB_OPT;
PERL_MM_OPT="INSTALL_BASE=/home/choucl/perl5"; export PERL_MM_OPT;
if [[ -n "$IN_NIX_SHELL" ]]; then
  export PS1="($name) $PS1"
fi

export TERM=xterm-256color

if [[ -d "/usr/local/cuda" ]]; then
  export PATH=/usr/local/cuda/bin:$PATH
  export CPATH=/usr/local/cuda/include:$CPATH
  export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
  export DYLD_LIBRARY_PATH=/usr/local/cuda/lib:$DYLD_LIBRARY_PATH
fi

# Include paths
export C_INCLUDE_PATH=$HOME/.local/include:$C_INCLUDE_PATH
export CPLUS_INCLUDE_PATH=$HOME/.local/include:$CPLUS_INCLUDE_PATH
export CPATH=$HOME/.local/include:$CPATH

if [[ -o interactive && -n "$SSH_CONNECTION" && -n "$SSH_TTY" && -t 1 && -z "$TMUX" && -z "$TERM_PROGRAM" ]]; then
  export TERM_PROGRAM=WezTerm
  export WEZTERM_PANE=1
fi

# >>> oh-my-opencode-slim background subagents >>>
export OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS=true
# <<< oh-my-opencode-slim background subagents <<<
